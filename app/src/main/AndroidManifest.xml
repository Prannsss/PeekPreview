<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Draw the peek bubble on top of Google Messages. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Persistent "PeekPreview is running" notification (runtime-granted on 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Keep the process alive / be transparent that we run in the background. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14 (SDK 34) requires a typed foreground service. There is no
         accessibility-specific type, so SPECIAL_USE is the honest fit. The
         <property> below documents the justification (required for this type). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.PeekPreview">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PeekPreview">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The accessibility service. BIND_ACCESSIBILITY_SERVICE means only the
             system can bind to it. The config lives in res/xml. -->
        <service
            android:name=".service.PeekAccessibilityService"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Foreground service. SPECIAL_USE requires this property on 14+. -->
        <service
            android:name=".service.PeekForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Keeps the PeekPreview accessibility overlay responsive and shows the user a persistent, dismissable notification while the feature is on." />
        </service>
    </application>
</manifest>
