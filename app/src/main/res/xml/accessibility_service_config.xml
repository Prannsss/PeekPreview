<?xml version="1.0" encoding="utf-8"?>
<!--
    Accessibility service config.

    accessibilityEventTypes: we listen for a *narrow* set rather than
    typeAllMask. Narrowing matters because onAccessibilityEvent is a hot path;
    typeAllMask means the system wakes us for every text change, scroll, and
    focus event across the target app, which is wasteful and makes the service
    feel heavier to the battery/perf teams (and to review). We keep:
      - typeViewLongClicked          -> the ideal "peek" trigger
      - typeViewAccessibilityFocused -> fallback trigger (see the service)
    Tradeoff: narrower = we might miss a device/app combo that fires some other
    event on long-press. If a target app doesn't cooperate, widen this here.

    packageNames: Messenger + Instagram only for now (Google Messages temporarily
    dropped). To support more apps, add them here and to SUPPORTED_APPS.

    canPerformGestures: we tap the row's screen position to open the chat for
    real after a peek, so the service needs gesture dispatch.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeViewLongClicked|typeViewAccessibilityFocused"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagRetrieveInteractiveWindows|flagReportViewIds"
    android:canPerformGestures="true"
    android:canRetrieveWindowContent="true"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="100"
    android:packageNames="com.facebook.orca,com.instagram.android"
    android:settingsActivity="com.peekpreview.MainActivity" />
